# ─── NAT 2.0 Production Environment Variables ─────────────────────────────────
#
# Copy this file to .env and fill in values for your deployment.
# All token/auth variables are opt-in: unset = permissive (local dev mode).

# ─── Core ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── Agent Authentication ──────────────────────────────────────────────────────
# Shared secret between server and remote agents. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TOKEN=

# ─── WebSocket Security ───────────────────────────────────────────────────────
# Set to "true" to require joinToken validation on recorder session joins.
WS_AUTH_REQUIRED=false

# Comma-separated list of allowed origins for WebSocket connections.
# Empty = allow all (suitable for local dev, not recommended for production).
# Example: https://nat.yourcompany.com,https://staging.nat.yourcompany.com
WS_ALLOWED_ORIGINS=

# ─── Chrome Extension ─────────────────────────────────────────────────────────
# Extension ID from the Chrome Web Store listing (used by recorder page for
# auto-detection via chrome.runtime.sendMessage).
CHROME_EXTENSION_ID=

# Public URL of the NAT server (used in extension auto-configure flow).
NAT_PUBLIC_URL=https://nat.yourcompany.com

# ─── Database (QE) ────────────────────────────────────────────────────────────
# QE_DATABASE_URL=mysql://user:password@host:3306/nat2o?ssl={"rejectUnauthorized":true}

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
