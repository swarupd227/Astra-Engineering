// Helper function to extract requirements from a single section's content
function extractRequirementsFromContent(
  content: string,
  sectionTitle: string,
): Array<{ name: string; description: string }> {
  const sectionResults: Array<{ name: string; description: string }> = [];
  if (!content || !content.trim()) {
    return sectionResults;
  }

  const lines = content.split(/\r?\n/);
  
  let inTable = false;
  let headerRowFound = false;
  let separatorRowFound = false;

  for (const rawLine of lines) {
    const line = rawLine.trim();
    
    const isTableRow = line.startsWith("|") && line.endsWith("|") && line.length > 2;
    
    if (!isTableRow) {
      if (inTable) {
        inTable = false;
        headerRowFound = false;
        separatorRowFound = false;
      }
      continue;
    }

    if (!inTable) {
      inTable = true;
      headerRowFound = false;
      separatorRowFound = false;
    }

    const isSeparatorRow = /^\|\s*[-:]+(\s*[-:]*\s*\|)*\s*$/.test(line);
    
    if (isSeparatorRow) {
      separatorRowFound = true;
      continue;
    }

    if (!headerRowFound && !separatorRowFound) {
      headerRowFound = true;
      continue;
    }

    const cells = line
      .split("|")
      .map((c: string) => c.trim())
      .filter((c: string) => c.length > 0);

    if (cells.length < 2) {
      continue;
    }

    const name = cells[0];
    const description = cells[1] || "";

    if (!name || name.trim().length === 0) {
      continue;
    }

    sectionResults.push({ name: name.trim(), description: description.trim() });
  }

  return sectionResults;
}
