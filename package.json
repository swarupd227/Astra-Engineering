  "scripts": {
    "prepare": "husky install",
    "postinstall": "npx puppeteer browsers install chrome || echo 'Puppeteer bundled Chrome install skipped' && (npx playwright install chromium || echo 'Playwright chromium install skipped — run: npm run playwright:install')",
    "playwright:install": "npx playwright install chromium",
    "dev": "cross-env NODE_ENV=development tsx watch server/index.ts",
    "build:qe": "vite build --config vite.config.qe.ts",
    "build": "vite build && npm run build:qe && esbuild server/index.ts --platform=node --bundle --format=cjs --outfile=dist/index.cjs --target=node20 --external:mysql2 --external:mysql2/promise --external:dotenv --external:vite --external:@vitejs/* --external:lightningcss --external:lightningcss-* --external:@babel/* --external:@replit/* --external:postcss --external:tailwindcss --external:autoprefixer --external:express --external:express-session --external:passport --external:passport-local --external:openid-client --external:memorystore --external:faiss-node --external:@langchain/langgraph --external:@sparticuz/chromium --external:puppeteer --external:puppeteer-core --external:playwright --external:playwright-core --external:@playwright/test --external:@azure/arm-appservice --external:@azure/arm-subscriptions --external:@azure/arm-resources --external:@azure/arm-sql --external:@azure/arm-postgresql-flexible --external:@azure/arm-mysql-flexible --external:@azure/identity --external:@aws-sdk/client-bedrock-runtime --external:@aws-sdk/client-s3 --external:@aws-sdk/client-secrets-manager --external:@aws-sdk/s3-request-presigner --external:./vite.config* --external:../vite.config* && node -e \"require('fs').copyFileSync('staticwebapp.config.json', 'dist/public/staticwebapp.config.json')\" && node -e \"require('fs').cpSync('server/assets', 'dist/server/assets', { recursive: true })\" && node -e \"require('fs').copyFileSync('nous-ai-vscode-1.0.0.vsix', 'dist/nous-ai-vscode-1.0.0.vsix')\" && node -e \"require('fs').copyFileSync('Plugin_Guide.md', 'dist/Plugin_Guide.md')\" && npm run build:smoketest",
    "build:smoketest": "node --check dist/index.cjs && node scripts/build-smoketest.js",
    "start": "node dist/index.cjs",
    "start:azure": "bash startup.sh",
    "check": "tsc",
    "db:bootstrap": "npm run db:preflight && cross-env RUN_DB_SEED=true npm run migrate:dev && npm run check:schema",
    "db:preflight": "node scripts/db-preflight.mjs",
    "db:privileges": "node scripts/db-preflight.mjs --privileges-only",
    "db:doctor": "node scripts/db-doctor.mjs",
    "db:push": "drizzle-kit push",
    "sync:qa": "tsx scripts/sync-qa-database.ts",
    "sync:qa-data": "tsx scripts/sync-qa-data.ts",
    "sync:qa-data:truncate": "tsx scripts/sync-qa-data.ts --truncate",
    "migrate:workflow-artifacts": "tsx scripts/apply-workflow-artifacts-migration.ts",
    "migrate:schema:generic": "tsx scripts/migrate-schema-generic.ts",
    "migrate:onboarding-backfill": "tsx scripts/backfill-onboarding-and-ownership.ts",
    "check:schema": "node scripts/check-schema-sync.js",
    "generate:migration": "node scripts/generate-migration.js",
    "migrate:dev": "node scripts/run-migration-improved.js",
    "migrate:container": "node scripts/run-container-migrations.js",
    "migrate:order:generate": "node scripts/generate-migration-order.js",
    "generate:full-schema": "node scripts/generate-full-schema-baseline.js",
    "migrate:check": "npm run check:schema && echo ✅ Ready to migrate",
    "check:migration-location": "node scripts/check-migration-location.js",
    "check:import-meta-guards": "node scripts/check-import-meta-guards.js",
    "check:lockfile": "node scripts/check-package-lock-sync.js",
    "fix:brd-id-nullable": "tsx scripts/fix-brd-id-nullable.ts",
    "test:anthropic": "tsx scripts/test-anthropic-connection.ts",
    "verify:hosting": "tsx scripts/verify-hosting-smoke.ts",
    "precommit": "npm run check:lockfile && npm run check:import-meta-guards && npm run check:schema",
    "build:chrome-extension": "node scripts/build-chrome-extension.mjs",
    "build:downloads": "node scripts/build-chrome-extension.mjs && cd remote-agent && npm run build:windows"
  },
