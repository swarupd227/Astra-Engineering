# ======================================================================
# DevX 2.0 — Environment Configuration
# ======================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# There are TWO hosting modes:
#   DEVX_HOSTING=aws   → Jira + Bedrock + Secrets Manager (+ MSAL or Cognito auth)
#   DEVX_HOSTING=azure → ADO + Azure OpenAI + MSAL (default)
#
# When DEVX_HOSTING=aws, the server fetches runtime config from AWS
# Secrets Manager at startup. Keys in SM overwrite hosting-specific
# values from this file (MYSQL_*, BEDROCK_*, JIRA_*, etc.).
# Local-only keys (USE_LOCAL_CODE_EXECUTION, etc.) are preserved.
#
# In PRODUCTION (EC2), no .env file is needed — systemd provides
# DEVX_HOSTING + AWS_REGION + AWS_SECRET_NAME, and IAM Instance
# Profile provides authentication. All config comes from SM.
# ======================================================================

# ----------------------------------------------------------------------
# 1. HOSTING MODE (required)
# ----------------------------------------------------------------------
DEVX_HOSTING=aws
VITE_DEVX_HOSTING=aws

# Auth mode — msal (Azure AD / Entra), cognito/amplify (AWS), or keycloak (test OIDC)
DEVX_AUTH_MODE=msal
VITE_AUTH_MODE=msal

# Azure AD / Entra (required when DEVX_AUTH_MODE=msal)
# VITE_AZURE_AD_CLIENT_ID=your-azure-ad-client-id
# VITE_AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Keycloak / generic OIDC (testing only; set DEVX_AUTH_MODE=keycloak and VITE_AUTH_MODE=keycloak)
# OIDC_ENABLED=false
# OIDC_PROVIDER_ID=keycloak
# OIDC_ISSUER=http://localhost:8080/realms/astra
# OIDC_CLIENT_ID=astra-local
# OIDC_CLIENT_SECRET=
# OIDC_TENANT_CLAIM=
# OIDC_CLOCK_TOLERANCE_SECONDS=300
# OIDC_TOKEN_ENDPOINT=
# OIDC_JWKS_URI=
# VITE_OIDC_ENABLED=false
# VITE_OIDC_PROVIDER_ID=keycloak
# VITE_OIDC_PROVIDER_NAME=Keycloak
# VITE_OIDC_AUTHORITY=http://localhost:8080/realms/astra
# VITE_OIDC_CLIENT_ID=astra-local
# VITE_OIDC_REDIRECT_URI=http://localhost:4000/
# VITE_OIDC_SCOPE=openid profile email
# VITE_OIDC_CLOCK_TOLERANCE_SECONDS=300
# VITE_OIDC_PROVIDER_LOGOUT_ENABLED=true
# VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:4000/

# Public WebSocket URL exposed to the Chrome extension when the app is fronted
# by something that does NOT support WebSocket upgrades (e.g. AWS API Gateway
# HTTP API). Format: ws://host:port (or wss://) — the extension appends
# /ws/recorder. Leave unset for localhost / Azure App Service (origin works).
# Example: EXTENSION_WS_PUBLIC_URL=ws://ec2-13-206-52-191.ap-south-1.compute.amazonaws.com:4000
# EXTENSION_WS_PUBLIC_URL=

# NAT 2.0 download artifacts (chrome extension + remote agent zips) on S3.
# Falls back to S3_DESIGN_BUCKET when NAT_S3_BUCKET is unset.
# NAT_S3_BUCKET=your-bucket-name
# NAT_S3_PREFIX=NAT-Extensions
# S3_DESIGN_BUCKET=your-bucket-name

# ----------------------------------------------------------------------
# 2. AWS BOOTSTRAP (only used for local dev; on EC2 the IAM Instance Profile takes over)
#    Needs an IAM user with `secretsmanager:GetSecretValue` on devx/platform/qa
# ----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_SECRET_NAME=devx/platform/qa

# ----------------------------------------------------------------------
# 3. VITE BUILD-TIME VARS (embedded in the frontend at build; can't come from SM)
#    Cognito — uncomment when DEVX_AUTH_MODE=cognito
# ----------------------------------------------------------------------
# VITE_COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
# VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_REGION=ap-south-1
# VITE_COGNITO_DOMAIN=devx-platform
VITE_FEATURE_SDLC=true
VITE_FEATURE_QUICK_WORKFLOW=true
VITE_FEATURE_STACK_MODERNIZATION=true

# ----------------------------------------------------------------------
# 4. SESSION & ENCRYPTION (loaded from SM in AWS mode)
# ----------------------------------------------------------------------
SESSION_SECRET="generate-a-random-64-char-string"
PAT_ENCRYPTION_KEY="your-encryption-key"

# ----------------------------------------------------------------------
# 5. AZURE MODE ONLY — Uncomment when DEVX_HOSTING=azure
#    These are not needed when DEVX_HOSTING=aws (SM provides them).
# ----------------------------------------------------------------------
# MYSQL_HOST=your-server.mysql.database.azure.com
# MYSQL_PORT=3306
# MYSQL_USER=your-username
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=your-database

# AWS Aurora QA (EKS / client deploy)
# MYSQL_HOST=devx-aurora-qa.cluster-cl2o06u2grip.ap-south-1.rds.amazonaws.com
# MYSQL_PORT=3306
# MYSQL_USER=your-rds-user
# MYSQL_PASSWORD=your-rds-password
# MYSQL_DATABASE=qadevxdb

# Local DB test mode. Preserves MYSQL_* from this file even when AWS Secrets Manager loads.
# DEVX_USE_LOCAL_DB=true
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=devxlocal
# MYSQL_PASSWORD=devxlocal123
# MYSQL_DATABASE=qadevxdb

# ADO_ORG=YourOrg
# ADO_PROJECT=YourProject
# ADO_PAT=your-ado-pat

# AZURE_API_KEY=your-azure-api-key
# AZURE_ENDPOINT=https://your-foundry.services.ai.azure.com/...
# DEPLOYMENT_NAME=your-deployment

# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/

# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_EMBEDDING_ENDPOINT=https://your-embedding-endpoint.openai.azure.com/
# AZURE_EMBEDDING_API_KEY=your-embedding-key
# AZURE_EMBEDDING_API_VERSION=2023-05-15

# ANTHROPIC_AZURE_ENDPOINT=https://your-endpoint.services.ai.azure.com/anthropic/v1/messages
# ANTHROPIC_API_KEY=your-key
# ANTHROPIC_MODEL_NAME=claude-sonnet-4-5
# ANTHROPIC_MODEL_VERSION=2023-06-01

# ----------------------------------------------------------------------
# 6. GITHUB (loaded from SM in AWS mode)
# ----------------------------------------------------------------------
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_OWNER=YourOrg
# GITHUB_REPO=YourRepo
# GITHUB_BRANCH=main

# ----------------------------------------------------------------------
# 7. LOGGING (server — structured JSON is on by default)
# ----------------------------------------------------------------------
# STRUCTURED_LOGS=false
# LOG_LEVEL=info

# ----------------------------------------------------------------------
# 8. LOCAL DEVELOPMENT ONLY (never stored in Secrets Manager)
# ----------------------------------------------------------------------
# STACK_MODERNIZATION_SKIP_AUTH=true
# USE_LOCAL_CODE_EXECUTION=true
# CODE_EXECUTION_BASE_DIR=C:\Code
# RAG_PIPELINE_MODE=rag_pageindex
# RAG_COVERAGE_CHECK=true

# ----------------------------------------------------------------------
# 9. FILESYSTEM ANCHORING FOR THE BUNDLED CJS SERVER
# ----------------------------------------------------------------------
# Anchors the repo root used by server-side code that reads files relative to
# the application's install directory (specs/, recorded-scripts/, etc.).
# - Production (EC2):  set this to the directory that contains `dist/`,
#                      typically `/opt/devx`.
# - Local dev (tsx):   leave unset; server/utils/module-paths.ts derives the
#                      root from the entry script's parent directory.
# Why this exists: in the bundled CJS output (dist/index.cjs), every source
# file collapses into one bundle, so per-file `__dirname` plus `..` math is
# wrong at runtime. See server/utils/module-paths.ts and the 502 RCA.
# DEVX_REPO_ROOT=/opt/devx

# ----------------------------------------------------------------------
# POLARIS AI-METRICS API  (GET /api/ai-metrics — DevX is the VERIFIER only)
# ----------------------------------------------------------------------
# Polaris signs an RS256 JWT with its PRIVATE key; DevX verifies with the matching
# PUBLIC key configured here. DevX never holds the private key.
# Provide EITHER a static SPKI PEM public key (preferred for this setup) ...
#   POLARIS_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ... OR a JWKS endpoint whose key is published under kid "polaris-key3567":
#   POLARIS_JWKS_URI=https://polaris.example.com/.well-known/jwks.json
#
# Expected token claims: iss=polaris, aud=devx-metrics, sub=polaris-backend,
# scope includes "metrics.read", exp-iat <= 300s. No tenant_id is required or used.
