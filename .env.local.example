# ======================================================================
# Astra Engineering — LOCAL Docker config
# Copy to .env.local and fill in your Anthropic key:
#   cp .env.local.example .env.local
# Then: docker compose -f docker-compose.local.yml up --build
# ======================================================================

# --- Hosting / provider -----------------------------------------------
# azure mode reads config straight from this file (no AWS Secrets Manager).
DEVX_HOSTING=azure
VITE_DEVX_HOSTING=azure

# --- LLM: DIRECT Anthropic API ----------------------------------------
# Use your own Anthropic key. Because ANTHROPIC_AZURE_ENDPOINT is NOT set,
# the app talks directly to https://api.anthropic.com with x-api-key auth.
SELECTED_LLM=ANTHROPIC
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
ANTHROPIC_MODEL_NAME=claude-sonnet-4-5
ANTHROPIC_MODEL_VERSION=2023-06-01
# Optional override (defaults to https://api.anthropic.com/v1/messages):
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# --- Database (points at the mysql compose service) -------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=devxlocal
MYSQL_DATABASE=devxdb

# --- App secrets (local only — generate your own) ---------------------
# 32-char key used to encrypt stored integration tokens.
PAT_ENCRYPTION_KEY=local-dev-pat-encryption-key-32ch
SESSION_SECRET=local-dev-session-secret-change-me

# --- Auth: local Keycloak / OIDC --------------------------------------
# Backend OIDC (runtime). host.docker.internal resolves to the host from inside
# the container, so the app can reach Keycloak and the token issuer matches.
DEVX_AUTH_MODE=keycloak
VITE_AUTH_MODE=keycloak
OIDC_ENABLED=true
OIDC_PROVIDER_ID=keycloak
OIDC_ISSUER=http://host.docker.internal:8080/realms/astra
OIDC_CLIENT_ID=astra-local
OIDC_CLIENT_SECRET=
OIDC_CLOCK_TOLERANCE_SECONDS=300
# NOTE: the VITE_OIDC_* values below are baked at build time via
# docker-compose.local.yml build args — these runtime copies are informational.
VITE_OIDC_ENABLED=true
VITE_OIDC_PROVIDER_ID=keycloak
VITE_OIDC_PROVIDER_NAME=Keycloak
VITE_OIDC_AUTHORITY=http://host.docker.internal:8080/realms/astra
VITE_OIDC_CLIENT_ID=astra-local
VITE_OIDC_REDIRECT_URI=http://localhost:4000/
VITE_OIDC_SCOPE=openid profile email
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:4000/

# --- Misc -------------------------------------------------------------
PORT=4000
DEVX_PROMPT_CACHE=1
