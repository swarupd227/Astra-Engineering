<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="NAT2.0 Regression Suite"
       parallel="methods"
       thread-count="3"
       verbose="1">

    <listeners>
        <listener class-name="org.testng.reporters.SuiteHTMLReporter"/>
    </listeners>

    <!-- SMOKE — fast, critical path tests only -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.nat.tests.LoginTest"/>
        </classes>
    </test>

    <!-- FUNCTIONAL — all functional tests -->
    <test name="Functional Tests">
        <groups>
            <run>
                <include name="functional"/>
            </run>
        </groups>
        <classes>
            <class name="com.nat.tests.LoginTest"/>
        </classes>
    </test>

    <!-- REGRESSION — full suite including edge cases -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.nat.tests.LoginTest"/>
        </classes>
    </test>

</suite>
